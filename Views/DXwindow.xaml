<Window x:Class="DXTnavis.Views.DXwindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DXTnavis.Views"
        xmlns:converters="clr-namespace:DXTnavis.Converters"
        mc:Ignorable="d"
        Title="DXTnavis 속성 확인기" Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- 컨버터 리소스 -->
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- 버튼 스타일 -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 초록색 성공 버튼 스타일 (업로드용) -->
        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="4" 
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#45A049"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid 헤더 스타일 -->
        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="40"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <!-- 왼쪽 패널: 객체 계층 구조 TreeView -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 상단: 타이틀 및 설명 -->
            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="객체 계층 구조" FontSize="16" FontWeight="Bold" Foreground="#333333"/>
                <TextBlock Text="객체를 선택하여 속성 확인"
                           FontSize="10" Foreground="#666666" Margin="0,3,0,0"/>
            </StackPanel>

            <!-- 중앙: TreeView -->
            <Border Grid.Row="1" BorderBrush="#DDDDDD" BorderThickness="1" Background="White">
                <TreeView x:Name="ObjectHierarchyTree"
                          ItemsSource="{Binding ObjectHierarchyRoot}"
                          BorderThickness="0">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          Margin="0,0,5,0"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Border>

            <!-- 하단: 버튼 -->
            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                <Button Content="모델 계층 로드"
                        Style="{StaticResource ActionButton}"
                        Command="{Binding LoadHierarchyCommand}"/>
            </StackPanel>
        </Grid>

        <!-- 구분선 -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#CCCCCC"/>

        <!-- 중간 패널: 선택된 객체들의 속성 표시 및 선택 -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 상단: 타이틀 및 설명 -->
            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="선택된 객체의 속성" FontSize="16" FontWeight="Bold" Foreground="#333333"/>
                <TextBlock Text="체크박스로 속성을 선택하여 검색 세트 생성 가능"
                           FontSize="10" Foreground="#666666" Margin="0,3,0,0"/>
            </StackPanel>

            <!-- 중앙: 속성 목록 DataGrid (체크박스 포함) -->
            <Border Grid.Row="1" BorderBrush="#DDDDDD" BorderThickness="1" Background="White">
                <DataGrid x:Name="PropertiesDataGrid"
                          ItemsSource="{Binding AllHierarchicalProperties}"
                          AutoGenerateColumns="False"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          AlternatingRowBackground="#F9F9F9"
                          RowBackground="White"
                          ColumnHeaderStyle="{StaticResource DataGridHeaderStyle}"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="선택" Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                        <DataGridTextColumn Header="객체" Binding="{Binding DisplayName}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="카테고리" Binding="{Binding Category}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="속성" Binding="{Binding PropertyName}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="값" Binding="{Binding PropertyValue}" Width="*" IsReadOnly="True"/>
                        <!-- PRD v7: 속성 권한 상태 표시 컬럼 -->
                        <DataGridTextColumn Header="권한" Binding="{Binding ReadWriteStatus}" Width="100" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- 전체 모델 내보내기 섹션 -->
            <GroupBox Grid.Row="2" Header="📁 파일 내보내기" Padding="10" Margin="0,10,0,0">
                <StackPanel>
                    <!-- 내보내기 버튼 -->
                    <StackPanel Orientation="Horizontal">
                        <Button Content="전체 속성 CSV 저장"
                                Style="{StaticResource ActionButton}"
                                Command="{Binding ExportAllToCsvCommand}"/>
                        <Button Content="계층 구조 내보내기"
                                Style="{StaticResource ActionButton}"
                                Command="{Binding ExportSelectionHierarchyCommand}"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- 구분선 -->
        <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="#CCCCCC"/>

        <!-- 오른쪽 패널: TabControl -->
        <TabControl Grid.Column="4" Background="White">
            <!-- 탭 1: 검색 세트 생성 -->
            <TabItem Header="🔍 검색 세트 생성">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 상단: 타이틀 및 설명 -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="검색 세트 생성" FontSize="16" FontWeight="Bold" Foreground="#333333"/>
                        <TextBlock Text="선택된 속성으로 검색 세트 생성"
                                   FontSize="10" Foreground="#666666" Margin="0,3,0,0"/>
                    </StackPanel>

                    <!-- 선택된 속성 개수 표시 -->
                    <Border Grid.Row="1" BorderBrush="#0078D4" BorderThickness="2" Background="#E6F3FF" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="선택된 속성 개수:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding SelectedPropertiesCount, FallbackValue='0개 선택됨'}"
                                       FontSize="14" Foreground="#0078D4"/>
                        </StackPanel>
                    </Border>

                    <!-- 폴더 이름 입력 -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,8">
                        <TextBlock Text="폴더 이름:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding FolderName, UpdateSourceTrigger=PropertyChanged}" Height="28"/>
                    </StackPanel>

                    <!-- 세트 이름 입력 -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,8">
                        <TextBlock Text="세트 이름:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding NewSetName, UpdateSourceTrigger=PropertyChanged}" Height="28"/>
                    </StackPanel>

                    <!-- 선택된 속성 정보 미리보기 -->
                    <GroupBox Grid.Row="4" Header="선택된 속성 미리보기" Padding="8" Margin="0,0,0,10">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="200">
                            <TextBlock Text="{Binding SelectedPropertyInfo, FallbackValue='(중간 패널에서 속성을 체크하세요)'}"
                                       TextWrapping="Wrap" FontSize="10" Foreground="#666666"/>
                        </ScrollViewer>
                    </GroupBox>

                    <!-- 생성 버튼 -->
                    <Button Grid.Row="5"
                            Content="검색 세트 생성"
                            Style="{StaticResource ActionButton}"
                            HorizontalAlignment="Stretch"
                            Command="{Binding CreateSearchSetCommand}"/>
                </Grid>
            </TabItem>

            <!-- 탭 2: 정보 -->
            <TabItem Header="ℹ️ 정보">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 제목 -->
                        <TextBlock Grid.Row="0"
                                   Text="DXTnavis"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#0078D4"
                                   Margin="0,0,0,5"/>

                        <TextBlock Grid.Row="1"
                                   Text="Navisworks 2025 Property Viewer"
                                   FontSize="12"
                                   Foreground="#666666"
                                   Margin="0,0,0,20"/>

                        <!-- 기능 설명 -->
                        <Border Grid.Row="2"
                                BorderBrush="#DDDDDD"
                                BorderThickness="1"
                                Background="#F9F9F9"
                                Padding="15"
                                Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock Text="주요 기능" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                                <TextBlock Text="• 전체 속성 CSV 저장" Margin="0,0,0,5"/>
                                <TextBlock Text="  모델의 모든 속성을 CSV로 내보내기"
                                           FontSize="10" Foreground="#666666" Margin="15,0,0,10"/>

                                <TextBlock Text="• 계층 구조 내보내기" Margin="0,0,0,5"/>
                                <TextBlock Text="  선택된 객체의 계층 구조를 CSV/JSON으로 저장"
                                           FontSize="10" Foreground="#666666" Margin="15,0,0,10"/>

                                <TextBlock Text="• 검색 세트 생성" Margin="0,0,0,5"/>
                                <TextBlock Text="  속성 기반 Navisworks 검색 세트 자동 생성"
                                           FontSize="10" Foreground="#666666" Margin="15,0,0,10"/>

                                <TextBlock Text="• 모델 계층 로드" Margin="0,0,0,5"/>
                                <TextBlock Text="  전체 모델 구조를 TreeView로 탐색"
                                           FontSize="10" Foreground="#666666" Margin="15,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- 버전 정보 -->
                        <Border Grid.Row="3"
                                BorderBrush="#DDDDDD"
                                BorderThickness="1"
                                Background="White"
                                Padding="15"
                                VerticalAlignment="Bottom">
                            <StackPanel>
                                <TextBlock Text="버전 정보" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock Text="버전: 1.0.0" FontSize="11" Margin="0,0,0,3"/>
                                <TextBlock Text="대상: Navisworks Manage 2025" FontSize="11" Margin="0,0,0,3"/>
                                <TextBlock Text="프레임워크: .NET Framework 4.8" FontSize="11" Margin="0,0,0,3"/>
                                <TextBlock Text="GitHub: github.com/tygwan/DXTnavis"
                                           FontSize="11" Foreground="#0078D4"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
